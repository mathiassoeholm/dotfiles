{
  "$schema": "/Users/dkmajuso/.pi/agent/git/github.com/MasuRii/pi-permission-system/schemas/permissions.schema.json",
  "defaultPolicy": {
    "tools": "allow",
    "bash": "allow",
    "mcp": "allow",
    "skills": "allow",
    "special": "allow"
  },
  "bash": {
    "jira *": "ask",
    "jira help *": "allow",
    "jira * --help": "allow",
    "jira * -h": "allow",
    "jira me": "allow",
    "jira issue list *": "allow",
    "jira issue view *": "allow",
    "jira sprint list *": "allow",
    "jira epic list *": "allow",
    "jira board list *": "allow",
    "jira project list *": "allow",
    "jira open *": "allow",

    "gh *": "ask",
    "gh api": "allow",
    "gh api *": "allow",
    "gh help *": "allow",
    "gh * --help": "allow",
    "gh * -h": "allow",
    "gh status": "allow",
    "gh status *": "allow",
    "gh * list": "allow",
    "gh * list *": "allow",
    "gh * view": "allow",
    "gh * view *": "allow",
    "gh * status": "allow",
    "gh * status *": "allow",
    "gh browse": "allow",
    "gh browse *": "allow",
    "gh search *": "allow",
    "gh pr diff *": "allow",

    "git *": "ask",
    "git add .": "allow",
    "git status": "allow",
    "git status *": "allow",
    "git diff": "allow",
    "git diff *": "allow",
    "git log": "allow",
    "git log *": "allow",
    "git show": "allow",
    "git show *": "allow",
    "git branch": "allow",
    "git branch --list": "allow",
    "git branch --list *": "allow",
    "git branch --show-current": "allow",
    "git remote -v": "allow",
    "git remote get-url *": "allow",
    "git config --get *": "allow",
    "git config --list": "allow",
    "git rev-parse *": "allow",
    "git ls-files": "allow",
    "git ls-files *": "allow",
    "git mv *": "allow",
    "git blame *": "allow",
    "git shortlog *": "allow",
    "git describe *": "allow",
    "git stash list": "allow",
    "git stash show": "allow",
    "git stash show *": "allow",
    "git fetch": "allow",
    "git fetch *": "allow",
    "git pull": "allow",
    "git pull *": "allow",
    "git push --set-upstream origin *": "allow",
    "git worktree list": "allow",
    "git worktree add ../*": "allow",
    "git restore": "allow",
    "git restore *": "allow",

    "firebase *": "ask",

    "aws *": "ask",
    "aws sts get-caller-identity": "allow",
    "aws configure list-profiles": "allow",
    "aws s3 ls *": "allow",
    "aws rds describe-db-clusters *": "allow",
    "aws backup list-recovery-points-by-resource *": "allow",

    "amma *": "ask",
    "amma help *": "allow",
    "amma * help *": "allow",
    "amma * --help": "allow",
    "amma * -h": "allow",
    "amma * -V": "allow",
    "amma * --version": "allow",
    "amma apis get *": "allow",
    "amma apis pending-connections *": "allow",
    "amma workspaces list *": "allow",
    "amma workspaces get *": "allow",
    "amma workspaces pending-connections *": "allow",
    "amma workspaces identity *": "allow",
    "amma workspaces allowed-subdomains *": "allow",
    "amma specifications get *": "allow",
    "amma collaborators get *": "allow",
    "amma configuration get *": "allow",
    "amma connection-requests list *": "allow",
    "amma connection-requests get *": "allow",
    "amma connection-requests me": "allow",
    "amma connection-requests me *": "allow",
    "amma users me": "allow",
    "amma users me *": "allow",
    "amma users workspaces *": "allow",
    "amma utilities validate-specification *": "allow",

    "pip *": "ask",
    "pip3 *": "ask",

    "sudo *": "ask",
    "rm -rf *": "ask",
    "dd *": "ask",
    "mkfs *": "ask",
    "shutdown *": "ask",
    "reboot *": "ask"
  }
}
